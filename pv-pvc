# PV/PVC
apiVersion: v1
kind: PersistentVolume
metadata:
  name: task-pv-volume-ollama
  labels:
    type: local
spec:
  capacity:
    storage: 10Gi
  accessModes:
    - ReadWriteMany
  hostPath:
    path: "/mnt/data"

---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: task-pv-claim-ollama
spec:
  volumeName: task-pv-volume-ollama
  accessModes:
    - ReadWriteMany
  resources:
    requests:
      storage: 10Gi
